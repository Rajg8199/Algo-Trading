# ── Postgres / TimescaleDB ────────────────────────────────────────────────
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=change-me

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Upstox ────────────────────────────────────────────────────────────────
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=https://your-domain.example/api/v1/auth/upstox/callback
# Conservative client-side budgets; verify current plan limits before raising.
UPSTOX_REST_RATE_LIMIT_PER_SEC=20
UPSTOX_WS_MAX_INSTRUMENTS=400

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# ── Service ports (host side) ─────────────────────────────────────────────
API_PORT=8000
RECORDER_HEALTH_PORT=8001
SCHEDULER_HEALTH_PORT=8002
TELEGRAM_HEALTH_PORT=8003

# ── Recorder ──────────────────────────────────────────────────────────────
RECORDER_CHAIN_POLL_SECONDS=60
RECORDER_BATCH_MAX_ROWS=500
RECORDER_BATCH_FLUSH_SECONDS=1.0
RECORDER_ATM_STRIKE_WINDOW=15

# ── Data lake root (host path mounted into containers) ───────────────────
DATALAKE_ROOT=/data/datalake

# ── ClickHouse (optional analytics profile) ───────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=analytics

# ── Environment: dev | prod ───────────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=INFO
